# Disclosure data lives outside version control — it's bulky, regenerable
# (`openhouse pull`/`parse`), and carries the §1 legal use restriction.
data/

.DS_Store
.env
.idea
.venv
.vscode
__pycache__
*.py[oc]
*.swo
*.swp
*.egg-info
build
dist
wheels/
Thumbs.db

# Frontend (web/inspect) contributor build deps. The *built* bundle is committed
# under openhouse/inspect/static (not dist/, which is ignored above) so
# `openhouse inspect` runs with zero Node at runtime.
node_modules/

# .claude/ holds both shared tooling (tracked below) and personal/transient
# state (ignored). Ignore everything, then re-include the shared artifacts.
.claude/*
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
!.claude/skills/
# Per-repo config for the vendored ship/ultraship skills (authored here, never
# pressed). The skills read these; everything repo-specific lives in them.
!.claude/ship.toml
!.claude/ultraship.toml
# Provenance stamp left by the press: machine-local (drawer path + file hashes),
# so a clone with no drawer self-skips its drift check. Never committed.
.claude/skills/*/.stamp
.claude/scratch
